# Copy this file to .env and fill in real values.

# Set to true once you've dropped a real service account key at FIREBASE_CREDENTIALS_PATH.
# While false, the app uses a local-disk JSON store (backend/local_data/) so you can
# develop and run tests without any Firebase project set up yet.
# Note: raw uploaded files always stay on local disk even when this is true --
# Cloud Storage for Firebase requires the paid Blaze plan; Firestore itself is
# free on Spark, and nothing in the app reads the raw file back after upload.
USE_FIREBASE=false

FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Claude API key, used for Phase 5 (contradiction detection) and Phase 6 (redlining).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

MAX_UPLOAD_MB=25
