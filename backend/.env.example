# Copy this file to .env and fill in real values.

# Set to true once you've dropped a real service account key at FIREBASE_CREDENTIALS_PATH.
# While false, the app uses a local-disk JSON store (backend/local_data/) so you can
# develop and run tests without any Firebase project set up yet.
# Note: raw uploaded files always stay on local disk even when this is true --
# Cloud Storage for Firebase requires the paid Blaze plan; Firestore itself is
# free on Spark, and nothing in the app reads the raw file back after upload.
USE_FIREBASE=false

FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Which AI provider powers Phase 5 (contradiction detection) and Phase 6
# (redlining): "claude" (default) or "gemini". Both ask the exact same
# question against the exact same schema -- see app/services/ai_schemas.py.
AI_PROVIDER=claude

# Claude API key, used when AI_PROVIDER=claude.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Gemini API key, used when AI_PROVIDER=gemini. gemini-flash-lite-latest is
# a Google-maintained alias (avoids pinned model names being retired later).
# On a free-tier key the full "flash" tier can return 503 "high demand";
# flash-lite has its own quota and responded reliably in testing -- swap to
# gemini-flash-latest once on a paid plan for higher-quality judgments.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

MAX_UPLOAD_MB=25
