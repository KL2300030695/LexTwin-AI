# Copy this file to .env and fill in real values.

# Set to true once you've dropped a real service account key at FIREBASE_CREDENTIALS_PATH.
# While false, the app uses a local-disk JSON store (backend/local_data/) so you can
# develop and run tests without any Firebase project set up yet.
# Note: raw uploaded files always stay on local disk even when this is true --
# Cloud Storage for Firebase requires the paid Blaze plan; Firestore itself is
# free on Spark, and nothing in the app reads the raw file back after upload.
USE_FIREBASE=false

FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Which AI provider powers contradiction detection, redlining, and Chat with
# Contract's answer synthesis: "local" (default, no API key, runs entirely
# on-machine but slow on CPU-only inference) or "gemini" (optional, requires
# your own GEMINI_API_KEY below, much faster). Gemini is never used unless
# you explicitly set this to "gemini" -- there is no hidden fallback.
AI_PROVIDER=local

# Local LLM (used when AI_PROVIDER=local) -- no API key needed. Runs
# entirely on-machine via llama-cpp-python. The GGUF file below is
# downloaded once from Hugging Face Hub on first use (~3.8GB) and cached
# locally after that. This is the 7B model, not the smaller/faster 3B --
# verified directly that the 3B model missed a real, unambiguous
# payment-term contradiction that the 7B model caught correctly. Swap to
# Qwen/Qwen2.5-3B-Instruct-GGUF + qwen2.5-3b-instruct-q4_k_m.gguf for a
# faster but less reliable model -- see app/services/local_llm_client.py.
LOCAL_LLM_REPO_ID=Qwen/Qwen2.5-7B-Instruct-GGUF
LOCAL_LLM_FILENAME=qwen2.5-7b-instruct-q3_k_m.gguf
LOCAL_LLM_CONTEXT_SIZE=4096

# Google / Gemini (used only when AI_PROVIDER=gemini). Get a key at
# https://aistudio.google.com/apikey -- never commit this file with a real
# key in it (already gitignored), and never paste a real key into a chat,
# issue, or PR.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

MAX_UPLOAD_MB=25
