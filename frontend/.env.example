# Copy this file to .env and fill in values from your Firebase project
# console: Project Settings -> General -> Your apps -> Web app.
#
# These are NOT secrets -- Firebase Web config only identifies the project;
# access is enforced by Firebase Auth + the backend's ID-token verification,
# not by hiding this file. Still gitignored here mainly so different
# environments (dev/staging/prod Firebase projects) don't have to share one
# hardcoded config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
